<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.SetmealDishMapper">
    <delete id="deleteBySetmealIds">
        delete from setmeal_dish where setmeal_id in
            <foreach collection="ids" item = "setmeal_id" separator="," open = "(" close = ")">
                #{setmeal_id}
            </foreach>
    </delete>

    <select id="getSetmealIdsByDishId" resultType="java.lang.Long">

--         动态SQL的编写，因为ids的个数不确定
        select setmeal_id from setmeal_dish where dish_id in
        <foreach collection="ids" item="dishId" separator="," open="(" close=")">
            #{dishId}
        </foreach>

    </select>
    <select id="getBySetmealId" resultType="com.sky.entity.SetmealDish">
        select * from setmeal_dish where setmeal_id = #{setmealId}
    </select>

    <insert id="insertBatch">
        insert into setmeal_dish (setmeal_id, dish_id, name, price, copies) values
        <foreach collection="setmealDishes" item="sd" separator=",">
            (
             #{sd.setmealId},
             #{sd.dishId},
             #{sd.name},
             #{sd.price},
             #{sd.copies}
            )
        </foreach>
    </insert>
</mapper>
